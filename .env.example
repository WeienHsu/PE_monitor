# 初始自選股（逗號分隔）
WATCHLIST=GOOGL,AAPL,MSFT

# 初始持倉（ticker:成本:股數，逗號分隔，沒有持倉可留空）
HOLDINGS=

# 歷史區間年數（預設 5）
PE_HISTORY_YEARS=5

# 進場百分位（預設 25）
ENTRY_PERCENTILE=25

# 出場百分位（預設 75）
EXIT_PERCENTILE=75

# ─── 新聞來源 ─────────────────────────────────────────────────────────────────
# Finnhub API Key（免費：60 req/min，https://finnhub.io）
FINNHUB_API_KEY=

# ─── Email 訊號變更通知 ────────────────────────────────────────────────────────
# Gmail 寄件帳號（需開啟兩步驟驗證並建立「應用程式密碼」）
# 設定方式：myaccount.google.com/apppasswords
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# 收件人（可與寄件人相同）
NOTIFICATION_EMAIL=recipient@example.com

# 是否啟用 Email 通知（true/false；同時需在 config.json 設定 smtp_enabled: true）
SMTP_ENABLED=false
